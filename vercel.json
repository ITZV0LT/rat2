{
  "version": 2,
  "framework": null,
  "buildCommand": "cp rat2.py public/rat2.py",
  "outputDirectory": "public",
  "installCommand": "",
  "headers": [
    {
      "source": "/install.bat",
      "headers": [
        { "key": "Content-Disposition", "value": "attachment; filename=\"install.bat\"" },
        { "key": "Content-Type", "value": "application/octet-stream" }
      ]
    },
    {
      "source": "/agent.exe",
      "headers": [
        { "key": "Content-Disposition", "value": "attachment; filename=\"agent.exe\"" },
        { "key": "Content-Type", "value": "application/octet-stream" }
      ]
    },
    {
      "source": "/rat2.py",
      "headers": [
        { "key": "Content-Disposition", "value": "attachment; filename=\"rat2.py\"" },
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ]
}
